arr = [2, 5, 10, 15, 23, 35, 48, 60, 75, 90, 105, 120]
target = 35

index, comparisons = interpolation_search(arr, target)

print("Array:", arr)
print("Searching for:", target)
print("Found at index:", index)
print("Comparisons:", comparisons)
print()

performance_analysis()